---
import { getEntry } from 'astro:content';

const profileEntry = await getEntry('profile', 'main');
const profile = profileEntry.data;
---

<section id="contact" class="py-20 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
  <div class="text-center mb-16 flex flex-col items-center">
    <div class="group inline-block cursor-default">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        <span class="text-green-600">Contáctame</span>
      </h2>
      <div class="h-1 bg-green-500 mx-auto rounded-full w-0 group-hover:w-full transition-all duration-500 ease-out"></div>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row gap-12">
    <!-- Contact Info -->
    <div class="w-full lg:w-5/12">
      <h3 class="text-2xl font-bold text-slate-900 mb-6">Información de Contacto</h3>
      <p class="text-slate-600 mb-8 leading-relaxed">
        ¿Estás interesado en trabajar conmigo o simplemente quieres saludar? ¡No dudes en contactarme por cualquiera de estos medios!
      </p>

      <ul class="space-y-6">
        {profile.phone && (
          <li class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-slate-50 border border-slate-200 flex items-center justify-center text-green-600 flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <div>
              <h4 class="text-slate-900 font-semibold">Teléfono</h4>
              <p class="text-slate-600">{profile.phone}</p>
            </div>
          </li>
        )}
        
        {profile.email && (
          <li class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-slate-50 border border-slate-200 flex items-center justify-center text-green-600 flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <h4 class="text-slate-900 font-semibold">Email</h4>
              <p class="text-slate-600">{profile.email}</p>
            </div>
          </li>
        )}

        <li class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-slate-50 border border-slate-200 flex items-center justify-center text-green-600 flex-shrink-0">
             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <div>
            <h4 class="text-slate-900 font-semibold">Locación</h4>
            <p class="text-slate-600">{profile.location}</p>
          </div>
        </li>

        {profile.linkedin && (
          <li class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-slate-50 border border-slate-200 flex items-center justify-center text-green-600 flex-shrink-0">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </div>
            <div>
              <h4 class="text-slate-900 font-semibold">LinkedIn</h4>
              <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="text-slate-600 hover:text-green-600 transition-colors">
                Ver perfil profesional
              </a>
            </div>
          </li>
        )}

        {profile.github && (
           <li class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-slate-50 border border-slate-200 flex items-center justify-center text-green-600 flex-shrink-0">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.803 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </div>
            <div>
              <h4 class="text-slate-900 font-semibold">GitHub</h4>
              <a href={profile.github} target="_blank" rel="noopener noreferrer" class="text-slate-600 hover:text-green-600 transition-colors">
                Ver repositorios de código
              </a>
            </div>
          </li>
        )}
      </ul>
    </div>

    <!-- Contact Form (Static Zero JS) -->
    <div class="w-full lg:w-7/12">
      <form class="bg-white shadow-sm p-8 rounded-xl border border-slate-200" action="https://formspree.io/f/placeholder" method="POST">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 mb-2">Tu Nombre</label>
            <input type="text" id="name" name="name" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-slate-900 focus:outline-none focus:border-green-500 transition-colors" placeholder="Ej. Juan Pérez" required />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Tu Email</label>
            <input type="email" id="email" name="email" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-slate-900 focus:outline-none focus:border-green-500 transition-colors" placeholder="Ej. juan@correo.com" required />
          </div>
        </div>
        <div class="mb-6">
          <label for="subject" class="block text-sm font-medium text-slate-700 mb-2">Asunto</label>
          <input type="text" id="subject" name="subject" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-slate-900 focus:outline-none focus:border-green-500 transition-colors" placeholder="Motivo de tu mensaje" required />
        </div>
        <div class="mb-6">
          <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Mensaje</label>
          <textarea id="message" name="message" rows="5" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-slate-900 focus:outline-none focus:border-green-500 transition-colors resize-none" placeholder="Escribe tu mensaje aquí..." required></textarea>
        </div>
        
        <button type="submit" class="w-full px-8 py-4 rounded-lg bg-green-500 text-white font-bold hover:bg-green-600 shadow-md transition-colors">
          Enviar Mensaje
        </button>
      </form>
    </div>
  </div>
</section>
