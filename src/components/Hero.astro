---
import { getEntry } from 'astro:content';

const profileEntry = await getEntry('profile', 'main');
const profile = profileEntry.data;
---
<header class="py-20 flex flex-col items-center text-center px-4">
  <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-slate-900 dark:text-white mb-4">
    {profile.name}
  </h1>
  <h2 class="text-xl md:text-2xl text-slate-600 dark:text-slate-300 mb-6 font-medium">
    {profile.title}
  </h2>
  <p class="max-w-2xl text-lg text-slate-500 dark:text-slate-400 mb-8 leading-relaxed">
    {profile.bio}
  </p>
  <div class="flex items-center justify-center gap-4 text-sm font-medium text-slate-500 dark:text-slate-400">
    <span class="flex items-center gap-1.5">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
      {profile.location}
    </span>
    <span class="flex items-center gap-1.5">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path></svg>
      {profile.english_level}
    </span>
  </div>
</header>
