---
import { getEntry } from "astro:content";

const profileEntry = await getEntry("profile", "main");
const profile = profileEntry.data;
---

<section
  id="home"
  class="relative min-h-[80vh] flex items-center justify-center pt-16 overflow-hidden"
>
  <!-- Dynamic Background Wrapper -->
  <div class="absolute inset-0 z-0 bg-[#0a0a0c]">
    <!-- Canvas Overlay for Moving Particles -->
    <canvas
      id="particles-bg"
      class="absolute inset-0 z-10 w-full h-full opacity-60"></canvas>
  </div>

  <div
    class="relative z-20 text-center px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto pointer-events-none"
  >
    <h1
      class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-6 tracking-tight pointer-events-auto"
    >
      <span class="text-green-500">{profile.name}</span>
    </h1>
    <h2
      class="text-2xl sm:text-3xl md:text-4xl text-slate-100 mb-2 font-bold pointer-events-auto"
    >
      {profile.title}
    </h2>
    {profile.subtitle && (
      <h3
        class="text-lg sm:text-xl md:text-2xl text-slate-300 mb-10 font-light italic pointer-events-auto"
      >
        {profile.subtitle}
      </h3>
    )}

    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4 pointer-events-auto"
    >
      <a
        href="#portfolio"
        class="w-full sm:w-auto px-8 py-3 rounded-full border-2 border-green-500 text-white hover:bg-green-500 hover:text-white transition-all font-semibold bg-white/5 backdrop-blur-sm"
      >
        Ver Proyectos
      </a>
      <a
        href="#contact"
        class="w-full sm:w-auto px-8 py-3 rounded-full border-2 border-green-500 text-white hover:bg-green-500 hover:text-white transition-all font-semibold bg-white/5 backdrop-blur-sm"
      >
        Contrátame
      </a>
    </div>
  </div>
</section>

<script>
  const canvas = document.getElementById("particles-bg") as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext("2d");
    let width = (canvas.width = canvas.offsetWidth);
    let height = (canvas.height = canvas.offsetHeight);
    let particles: Particle[] = [];

    class Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;

      constructor() {
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        this.vx = (Math.random() - 0.5) * 1;
        this.vy = (Math.random() - 0.5) * 1;
        this.size = Math.random() * 2 + 1;
      }

      update() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > width) this.vx *= -1;
        if (this.y < 0 || this.y > height) this.vy *= -1;
      }

      draw() {
        if (!ctx) return;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fillStyle = "#ffffff"; // white color
        ctx.fill();
      }
    }

    const init = () => {
      particles = [];
      // Adjust density based on screen space
      const particleCount = Math.floor((width * height) / 10000);
      const maxParticles = Math.min(particleCount, 120); // Cap to avoid lag

      for (let i = 0; i < maxParticles; i++) {
        particles.push(new Particle());
      }
    };

    const animate = () => {
      if (!ctx) return;
      ctx.clearRect(0, 0, width, height);

      for (let i = 0; i < particles.length; i++) {
        particles[i].update();
        particles[i].draw();

        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const distance = Math.sqrt(dx * dx + dy * dy);

          if (distance < 120) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(255, 255, 255, ${0.4 - distance / 300})`; // white with opacity based on distance
            ctx.lineWidth = 1;
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(animate);
    };

    window.addEventListener("resize", () => {
      width = canvas.width = canvas.offsetWidth;
      height = canvas.height = canvas.offsetHeight;
      init();
    });

    init();
    animate();
  }
</script>
