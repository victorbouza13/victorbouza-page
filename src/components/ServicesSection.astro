---
import { getCollection } from 'astro:content';

const services = await getCollection('services');
const sortedServices = services.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const getIcon = (name: string) => {
  switch (name) {
    case 'api':
      return `<svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>`;
    case 'database':
      return `<svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>`;
    case 'cloud':
      return `<svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>`;
    default:
      return `<svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`;
  }
};
---

<section id="services" class="py-20 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto bg-slate-50">
  <div class="text-center mb-16 flex flex-col items-center">
    <div class="group inline-block cursor-default">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        Mis <span class="text-green-600">Servicios</span>
      </h2>
      <div class="h-1 bg-green-500 mx-auto rounded-full w-0 group-hover:w-full transition-all duration-500 ease-out"></div>
    </div>
    <p class="mt-6 text-slate-600 max-w-2xl mx-auto">
      Ofreciendo soluciones arquitectónicas de alto rendimiento usando las últimas tecnologías para cumplir con los objetivos del negocio.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {sortedServices.map((service) => (
      <div class="bg-white border border-slate-200 hover:border-green-500/50 hover:shadow-lg p-8 rounded-xl transition-all duration-300 group hover:-translate-y-2">
        <div class="w-16 h-16 bg-slate-50 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <Fragment set:html={getIcon(service.data.icon || 'default')} />
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-4 group-hover:text-green-600 transition-colors">
          {service.data.title}
        </h3>
        <p class="text-slate-600 leading-relaxed">
          {service.data.description}
        </p>
      </div>
    ))}
  </div>
</section>
