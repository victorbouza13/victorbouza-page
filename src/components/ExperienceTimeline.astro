---
import { getCollection, type CollectionEntry } from 'astro:content';

const experiences = await getCollection('experience');
const sortedExperiences = experiences.sort((a: CollectionEntry<'experience'>, b: CollectionEntry<'experience'>) => (a.data.order || 0) - (b.data.order || 0));

const renderedExperiences = await Promise.all(
  sortedExperiences.map(async (exp) => {
    const rendered = await exp.render();
    return { ...exp, Content: rendered.Content };
  })
);
---
<section id="resume" class="max-w-4xl mx-auto py-20 px-4 sm:px-6">
  <div class="text-center mb-16 flex flex-col items-center">
    <div class="group inline-block cursor-default">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        Mi <span class="text-green-600">Experiencia</span>
      </h2>
      <div class="h-1 bg-green-500 mx-auto rounded-full w-0 group-hover:w-full transition-all duration-500 ease-out"></div>
    </div>
  </div>

  <div class="relative border-l-2 border-slate-200 ml-3 md:mx-auto md:left-0 md:border-l-0">
    <!-- Center Line for Desktop -->
    <div class="hidden md:block absolute left-1/2 -ml-[1px] top-0 bottom-0 w-[2px] bg-slate-200"></div>

    {renderedExperiences.map((exp, index) => (
      <div class={`mb-12 relative w-full md:w-1/2 ${index % 2 === 0 ? 'md:pr-12 md:ml-0 md:text-right' : 'md:pl-12 md:ml-auto'} ml-6 md:ml-0`}>
          <!-- Dot Indicator -->
          <span class={`absolute flex items-center justify-center w-6 h-6 bg-green-100 rounded-full ring-4 ring-white -left-[35px] ${index % 2 === 0 ? 'md:-right-[12px] md:left-auto' : 'md:-left-[12px]'}`}>
            <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
          </span>
          
          <div class="bg-white border border-slate-200 shadow-sm p-6 rounded-xl hover:border-green-500/50 hover:shadow-md transition-all">
            <div class={`flex flex-col ${index % 2 === 0 ? 'md:items-end' : 'md:items-start'} mb-2`}>
              <h4 class="text-xl font-bold text-slate-900">
                {exp.data.title}
              </h4>
              <time class="text-sm font-medium text-green-600 mt-1">
                {exp.data.start_date} - {exp.data.end_date}
              </time>
            </div>
            
            <p class="text-sm font-semibold text-slate-700 mb-4">
              {exp.data.entity}
            </p>
            
            <div class={`text-slate-600 text-sm mb-6 leading-relaxed ${index % 2 === 0 ? 'md:text-right' : 'md:text-left'} text-left`}>
              <exp.Content />
            </div>
            
            <div class={`flex flex-wrap gap-2 mb-4 ${index % 2 === 0 ? 'md:justify-end' : 'justify-start'}`}>
              {exp.data.tech_stack.map((tech: string) => (
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-700 border border-slate-200">
                  {tech}
                </span>
              ))}
            </div>

            {(exp.data.repo_url || exp.data.ref_url) && (
               <div class={`flex gap-4 mt-4 ${index % 2 === 0 ? 'md:justify-end' : 'justify-start'}`}>
                {exp.data.repo_url && (
                  <a href={exp.data.repo_url} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-slate-500 hover:text-green-600 transition-colors">
                    Ver Repositorio
                  </a>
                )}
                {exp.data.ref_url && (
                  <a href={exp.data.ref_url} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-slate-500 hover:text-green-600 transition-colors">
                    Visitar Web
                  </a>
                )}
              </div>
            )}
          </div>
        </div>
    ))}
  </div>
</section>
