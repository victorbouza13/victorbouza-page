---
import { getCollection, type CollectionEntry } from 'astro:content';

const experiences = await getCollection('experience');
const sortedExperiences = experiences.sort((a: CollectionEntry<'experience'>, b: CollectionEntry<'experience'>) => (a.data.order || 0) - (b.data.order || 0));

// Resolvemos async renders en el frontmatter para prevenir errores de parsing TS en el template
const renderedExperiences = await Promise.all(
  sortedExperiences.map(async (exp) => {
    const rendered = await exp.render();
    return { ...exp, Content: rendered.Content };
  })
);
---
<section class="max-w-4xl mx-auto py-12 px-4 sm:px-6">
  <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">Experiencia Laboral</h3>
  <div class="relative border-l border-slate-200 dark:border-slate-700 ml-3">
    {renderedExperiences.map((exp) => (
      <div class="mb-10 ml-6 relative group">
          <span class="absolute flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full -left-9 ring-8 ring-white dark:ring-slate-900 dark:bg-blue-900">
            <div class="w-2 h-2 rounded-full bg-blue-500"></div>
          </span>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-1">
            <h4 class="text-lg font-semibold text-slate-900 dark:text-white">
              {exp.data.title}
            </h4>
            <time class="text-sm font-medium text-slate-500 dark:text-slate-400 mt-1 sm:mt-0">
              {exp.data.start_date} - {exp.data.end_date}
            </time>
          </div>
          <p class="text-sm font-medium text-blue-600 dark:text-blue-400 mb-3">
            {exp.data.entity}
          </p>
          <div class="text-slate-600 dark:text-slate-300 text-sm mb-4 leading-relaxed prose prose-sm dark:prose-invert">
            <exp.Content />
          </div>
          <div class="flex flex-wrap gap-2 mb-4">
            {exp.data.tech_stack.map((tech: string) => (
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                {tech}
              </span>
            ))}
          </div>
          {(exp.data.repo_url || exp.data.ref_url) && (
            <div class="mt-3">
              {exp.data.repo_url && (
                <a href={exp.data.repo_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-700 hover:text-blue-600 dark:text-slate-300 dark:hover:text-blue-400 transition-colors">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                  Ver Repositorio
                </a>
              )}
              {exp.data.ref_url && (
                <a href={exp.data.ref_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-700 hover:text-blue-600 dark:text-slate-300 dark:hover:text-blue-400 transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                  Visitar Plataforma
                </a>
              )}
            </div>
          )}
        </div>
    ))}
  </div>
</section>
