---
import { getCollection, type CollectionEntry } from 'astro:content';

const educations = await getCollection('education');
---
<section class="max-w-4xl mx-auto py-12 px-4 sm:px-6 mb-12">
  <div class="text-center mb-16 flex flex-col items-center">
    <div class="group inline-block cursor-default">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        Mi <span class="text-green-600">Formación</span>
      </h2>
      <div class="h-1 bg-green-500 mx-auto rounded-full w-0 group-hover:w-full transition-all duration-500 ease-out"></div>
    </div>
  </div>
  
  <div class="flex flex-col gap-6">
    {educations.map((edu: CollectionEntry<'education'>) => (
      <div class="flex flex-col sm:flex-row sm:items-center justify-between p-8 bg-white shadow-sm rounded-xl border border-slate-200 hover:border-green-500/50 hover:shadow-md transition-all group">
        <div class="flex items-start gap-4">
          <div class="mt-1 bg-slate-50 p-3 rounded-lg text-green-600 hidden sm:block group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 14l9-5-9-5-9 5 9 5z" /><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>
          </div>
          <div>
            <h4 class="text-xl font-bold text-slate-900 group-hover:text-green-600 transition-colors mb-1">
              {edu.data.degree}
            </h4>
            <p class="text-slate-600 text-sm">
              {edu.data.institution}
            </p>
          </div>
        </div>
        <div class="mt-4 sm:mt-0 sm:text-right">
          <span class="inline-block px-4 py-2 bg-slate-100 border border-slate-200 rounded-full text-sm font-medium text-green-700">
            {edu.data.year}
          </span>
        </div>
      </div>
    ))}
  </div>
</section>
