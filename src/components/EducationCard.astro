---
import { getCollection, type CollectionEntry } from 'astro:content';

const educations = await getCollection('education');
---
<section class="max-w-4xl mx-auto py-12 px-4 sm:px-6 mb-12">
  <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">Educación</h3>
  <div class="flex flex-col gap-4">
    {educations.map((edu: CollectionEntry<'education'>) => (
      <div class="flex flex-col sm:flex-row sm:items-center justify-between p-6 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-100 dark:border-slate-700/50">
        <div class="flex items-start gap-4">
          <div class="mt-1 bg-blue-100 dark:bg-blue-900/30 p-2 rounded-lg text-blue-600 dark:text-blue-400 hidden sm:block">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 14l9-5-9-5-9 5 9 5z" /><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>
          </div>
          <div>
            <h4 class="text-lg font-bold text-slate-900 dark:text-white">
              {edu.data.degree}
            </h4>
            <p class="text-slate-600 dark:text-slate-400 text-sm mt-1">
              {edu.data.institution}
            </p>
          </div>
        </div>
        <div class="mt-4 sm:mt-0 sm:text-right">
          <span class="inline-block px-3 py-1 bg-slate-200 dark:bg-slate-700 rounded-full text-sm font-medium text-slate-800 dark:text-slate-200">
            {edu.data.year}
          </span>
        </div>
      </div>
    ))}
  </div>
</section>
