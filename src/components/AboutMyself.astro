---
import { getEntry } from 'astro:content';
import victorProfile from '../assets/img/victor_profile.jpg';

const profileEntry = await getEntry('profile', 'main');
const profile = profileEntry.data;
---

<section id="about" class="py-20 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
  <div class="text-center mb-16 flex flex-col items-center">
    <div class="group inline-block cursor-default">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        Sobre <span class="text-green-600">Mí</span>
      </h2>
      <div class="h-1 bg-green-500 mx-auto rounded-full w-0 group-hover:w-full transition-all duration-500 ease-out"></div>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row gap-12 items-center">
    <!-- Image Column -->
    <div class="w-full lg:w-5/12">
      <div class="relative max-w-sm mx-auto">
        <div class="absolute inset-0 border-2 border-green-500 rounded-lg transform translate-x-4 translate-y-4 -z-10"></div>
        <img 
          src={victorProfile.src} 
          alt={profile.name} 
          class="w-full h-auto object-cover rounded-lg shadow-xl shadow-slate-200 grayscale hover:grayscale-0 transition-all duration-500 cursor-pointer"
        />
      </div>
    </div>

    <!-- Info Column -->
    <div class="w-full lg:w-7/12">
      <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-6">
        Hola, Soy <span class="text-green-600">{profile.name}</span>
      </h3>
      <p class="text-slate-600 mb-8 leading-relaxed text-lg">
        {profile.bio}
      </p>

      <ul class="space-y-3 mb-8">
        <li class="flex items-center text-lg">
          <span class="font-bold text-slate-900">Nombre:</span>
          <span class="text-slate-600 ml-2">{profile.name}</span>
        </li>
        {profile.age && (
          <li class="flex items-center text-lg">
            <span class="font-bold text-slate-900">Edad:</span>
            <span class="text-slate-600 ml-2">{profile.age}</span>
          </li>
        )}
        <li class="flex items-center text-lg">
          <span class="font-bold text-slate-900">Dirección:</span>
          <span class="text-slate-600 ml-2">{profile.location}</span>
        </li>
        {profile.phone && (
          <li class="flex items-center text-lg">
            <span class="font-bold text-slate-900">Teléfono:</span>
            <span class="text-slate-600 ml-2">{profile.phone}</span>
          </li>
        )}
        {profile.email && (
          <li class="flex items-center text-lg">
            <span class="font-bold text-slate-900">Email:</span>
            <span class="text-slate-600 ml-2">{profile.email}</span>
          </li>
        )}
        {profile.english_level && (
          <li class="flex items-center text-lg">
            <span class="font-bold text-slate-900">Idiomas:</span>
            <span class="text-slate-600 ml-2">Inglés {profile.english_level}</span>
          </li>
        )}
      </ul>

      {profile.cv_link && (
        <a 
          href={profile.cv_link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 rounded-full border-2 border-green-500 text-green-600 hover:bg-green-500 hover:text-white transition-all font-semibold"
        >
          Descargar CV
        </a>
      )}
    </div>
  </div>
</section>
